# coop — generic sandbox image for agent sessions.
#
# One image definition for all projects and users. Coop owns a locked core
# workbench; projects may add image-local tools through coop.toml and portable
# toolchains through their own optional Flox environments. The image contains
# no git identity or personal configuration.
# Embedded in the coop binary; build with `coop rebuild`.

# Digest-pinned base image; bump deliberately.
FROM ghcr.io/flox/flox:latest@sha256:04f2254909363974b049b6930a425f179bb1eaa194b1949198a44e4716a25782

# Configured tools resolve from one reviewed nixpkgs revision. The core
# environment has its own exact Flox lock.
ARG NIXPKGS_REF=github:flox/nixpkgs/d407951447dcd00442e97087bf374aad70c04cea

# Realize the release-owned core Flox environment. Only release artifacts are
# copied; Flox creates the Linux run links inside this image.
# Apple's BuildKit frontend drops the contents of a recursively copied hidden
# directory, so copy each release artifact explicitly.
COPY core/.flox/env.json /opt/coop-core/.flox/env.json
COPY core/.flox/env/manifest.toml /opt/coop-core/.flox/env/manifest.toml
COPY core/.flox/env/manifest.lock /opt/coop-core/.flox/env/manifest.lock
RUN flox activate --dir /opt/coop-core -- true

ENV COOP_CORE=/opt/coop-core
ENV COOP_TOOLS_PROFILE=/opt/coop-tools/profile
ENV PATH=/opt/coop-core/.flox/run/aarch64-linux.coop-core-run/bin:/nix/var/nix/profiles/default/bin:/usr/local/bin:/usr/bin:/bin

# Repository/global additions live in a lower-priority user-command profile.
# Each full installable is validated and materialized by Coop. Read it as a
# quoted value so package data is never shell source.
COPY configured-packages.txt /tmp/configured-packages.txt
RUN mkdir -p /opt/coop-tools && \
    while IFS= read -r installable; do \
      [ -n "$installable" ] || continue; \
      NIXPKGS_ALLOW_UNFREE=1 nix profile install \
        --profile /opt/coop-tools/profile \
        --extra-experimental-features "nix-command flakes" \
        --impure --priority 2 "$installable" || exit 1; \
    done < /tmp/configured-packages.txt && \
    rm /tmp/configured-packages.txt

# Guest HOME must equal host HOME for the identical-path property —
# every ~/-relative config resolves the same on both sides. The local image is
# built with a default; coop sets HOME at run time and ensures the directory
# exists, so the same image works per user.
ARG GUEST_HOME=/root
ENV HOME=$GUEST_HOME
ENV SHELL=zsh
ENV SSL_CERT_FILE=/opt/coop-core/.flox/run/aarch64-linux.coop-core-run/etc/ssl/certs/ca-bundle.crt

# zshrc lands both per-user (local builds) and globally (/etc/zshrc is
# read by zsh regardless of HOME, which covers images where HOME is decided at
# run time).
RUN mkdir -p "$GUEST_HOME" /usr/local/bin /etc
COPY zshrc $GUEST_HOME/.zshrc
COPY zshrc /etc/zshrc
COPY coop-user-env /usr/local/bin/coop-user-env
RUN chmod 0755 /usr/local/bin/coop-user-env

WORKDIR $GUEST_HOME

# Long-lived session container; entry happens via `container exec`.
CMD ["sleep", "infinity"]
