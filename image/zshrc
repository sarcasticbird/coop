# coop guest zshrc — slim, baked into the sandbox image.
# Host zsh config is never mounted; keep this minimal and portable.

export EDITOR=vi
export LANG=C.UTF-8

# History
HISTFILE="$HOME/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY HIST_IGNORE_DUPS

# Prompt — make it unmistakable that this shell is inside the coop
PROMPT='%F{yellow}[coop]%f %F{cyan}%~%f %# '
